# --- Azure Foundry (keyless preferred: run `az login`, use DefaultAzureCredential) ---
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# --- If using AzureChatOpenAI directly instead of the project endpoint ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
# check the current api-version in your Foundry portal / docs before setting:
AZURE_OPENAI_API_VERSION=

# --- LangSmith observability ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=email-assistant
